{
  "name": "@rogerchappel/handoffpad",
  "version": "0.1.0",
  "description": "Local-first agent handoff bundle builder.",
  "type": "module",
  "bin": {
    "handoffpad": "./dist/src/cli.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "typecheck": "npm run check",
    "test": "node --test dist/test/*.test.js",
    "pretest": "npm run build",
    "smoke": "npm run build && bash test/smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm test && npm run check && npm run build && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent",
    "handoff",
    "cli",
    "local-first",
    "redaction",
    "typescript"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/handoffpad.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/handoffpad/issues"
  },
  "homepage": "https://github.com/rogerchappel/handoffpad#readme"
}
